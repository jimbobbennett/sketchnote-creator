{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sketchnote layout",
  "type": "object",
  "required": ["title", "layout", "sections"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "maxLength": 60, "description": "Sentence case, Arize voice, no emoji" },
    "subtitle": { "type": "string", "maxLength": 80 },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "url": { "type": "string" },
        "channel": { "type": "string" },
        "duration": { "type": "string" }
      }
    },
    "layout": { "enum": ["grid"] },
    "hub": {
      "type": "object",
      "additionalProperties": false,
      "description": "radial layout: the central hub label",
      "properties": { "title": { "type": "string" }, "subtitle": { "type": "string" } }
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "theme": { "enum": ["light", "dark"], "default": "dark" },
        "aspect": { "enum": ["16:9", "1:1", "4:3", "2:1"], "default": "16:9" },
        "cols": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["header", "bullets"],
        "additionalProperties": false,
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "header": { "type": "string", "maxLength": 38, "description": "<=~6 words; a question works well" },
          "hue": { "enum": ["teal", "indigo", "purple", "magenta", "pink"] },
          "icon": { "type": "string", "description": "lucide icon name (kebab-case)" },
          "container": { "enum": ["box", "cloud", "bubble"], "description": "cell shape; default box. Use sparingly for emphasis/variety" },
          "emphasis": { "type": "boolean", "description": "draw a heavier border to make a keystone cell pop" },
          "figure": { "type": "string", "description": "path to a slide-derived sketch PNG (from slide-sketch.py); replaces the lucide icon" },
          "bullets": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": { "type": "string", "maxLength": 64 }
          },
          "quote": { "type": ["string", "null"], "maxLength": 90 }
        }
      }
    },
    "flow": {
      "type": "array",
      "description": "Arrows between section n's (popcorn/path/radial). [[1,2],[2,3]]",
      "items": { "type": "array", "items": { "type": "integer" }, "minItems": 2, "maxItems": 2 }
    },
    "decor": {
      "type": "object",
      "additionalProperties": false,
      "description": "Marginalia decoration pass (sparkles/stars/doodles in free zones)",
      "properties": {
        "density": { "enum": ["none", "light", "medium", "heavy"], "default": "light" },
        "seed": { "type": "integer", "description": "deterministic seed for doodle placement" }
      }
    },
    "footer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "left": { "type": "string" },
        "center": { "type": "string" },
        "right": { "type": "string" }
      }
    },
    "speakers": {
      "type": "array",
      "description": "Per-speaker sketch portraits (top-right). Generated by speaker-sketch.py.",
      "items": {
        "type": "object",
        "required": ["name", "portrait"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "role": { "type": "string" },
          "portrait": { "type": "string", "description": "path to the portrait PNG (relative to repo root)" }
        }
      }
    }
  }
}
